# Public (bundled into the browser — VITE_ prefix required)
VITE_WEB3FORMS_ACCESS_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (Vercel → Project Settings → Environment Variables)
# Do NOT use the VITE_ prefix for these. Redeploy after adding.
# Create a key at https://aistudio.google.com/apikey (format usually starts with AIzaSy).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional. If set, must include your live site origin, e.g. https://tekzura.com
# Leave empty on Vercel to allow same-origin requests only.
ALLOWED_ORIGINS=
